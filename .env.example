# ============================================
# 清徽半导体材料网站 - 环境变量配置
# ============================================
# Railway 部署: 在 Railway Dashboard → Variables 中添加
# 本地开发:   复制为 .env 并填入

# ===== Flask =====
SECRET_KEY=your-secret-key-here-min-32-chars-random
FLASK_DEBUG=false
FLASK_CONFIG=production

# ===== 数据库 =====
# Railway: 部署后会自动提供 DATABASE_URL，无需手动设置
# 本地开发: 留空自动使用 SQLite
# DATABASE_URL=

# ===== DeepSeek AI (必需) =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ===== 知识图谱 =====
# 后续部署KG平台后改为服务器内网地址
KG_API_BASE=http://localhost:5001/api
KG_PUBLIC_STATS=http://localhost:5001/api/public/stats

# ===== 通知服务 (二选一或都配置) =====
# Telegram: 在 @BotFather 创建 Bot，获取 Token
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 企业微信: 群机器人 Webhook
WECHAT_WEBHOOK_URL=

# ===== 网站 =====
# Railway 部署后替换为你的 Railway 域名或自定义域名
SITE_URL=https://www.vvnano.com

# ===== 管理后台 =====
# 修改为你的密码
ADMIN_PASSWORD=vvnano2025
